{
  "name": "kubiq",
  "displayName": "Kubiq",
  "description": "Standalone Kubernetes intelligence dashboard — pod diagnostics, crash analysis, multi-cluster management with AI",
  "version": "0.2.0",
  "publisher": "kubiq",
  "author": {
    "name": "Kubiq"
  },
  "icon": "media/kubiq-icon.png",
  "galleryBanner": {
    "color": "#0d0f14",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Debuggers"
  ],
  "keywords": [
    "kubernetes",
    "k8s",
    "eks",
    "gke",
    "aks",
    "pod",
    "diagnostics",
    "kubectl",
    "crash",
    "logs",
    "kubiq",
    "dashboard",
    "cluster"
  ],
  "activationEvents": [
    "onView:kubiq.dashboard",
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "kubiq-sidebar",
          "title": "Kubiq",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "kubiq-sidebar": [
        {
          "type": "webview",
          "id": "kubiq.dashboard",
          "name": "Kubiq"
        }
      ]
    },
    "commands": [
      {
        "command": "kubiq.diagnosePod",
        "title": "Kubiq: Diagnose Pod",
        "icon": "$(pulse)"
      },
      {
        "command": "kubiq.refresh",
        "title": "Kubiq: Refresh",
        "icon": "$(refresh)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "kubiq.refresh",
          "when": "view == kubiq.dashboard",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Kubiq",
      "properties": {
        "kubiq.clusterProfiles": {
          "type": "object",
          "default": {},
          "description": "Manual overrides: map kubeconfig context to AWS profile/region."
        },
        "kubiq.logTailLines": {
          "type": "number",
          "default": 500,
          "description": "Log lines to fetch per container"
        },
        "kubiq.ai.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable AI-powered diagnostics. Disable for offline/air-gapped mode. Crash pattern detection still works locally.",
          "order": 10
        },
        "kubiq.ai.customInstructions": {
          "type": "string",
          "default": "",
          "editPresentation": "multilineText",
          "description": "Additional instructions appended to the AI system prompt. Examples: 'Focus on Java Spring Boot errors', 'Always suggest Helm chart fixes', 'Respond in Japanese'.",
          "order": 11
        },
        "kubiq.ai.promptPreset": {
          "type": "string",
          "enum": [
            "default",
            "sre-oncall",
            "developer",
            "security-audit"
          ],
          "enumItemLabels": [
            "General K8s SRE",
            "SRE On-Call (incident focus)",
            "Developer (app-level focus)",
            "Security Audit (CVE/RBAC focus)"
          ],
          "default": "default",
          "description": "AI personality preset. Custom instructions are appended on top.",
          "order": 12
        },
        "kubiq.guardrails.sanitizeSecrets": {
          "type": "boolean",
          "default": true,
          "description": "Strip detected secrets, tokens, and credentials from pod data before sending to AI.",
          "order": 20
        },
        "kubiq.guardrails.sanitizeEnvVars": {
          "type": "boolean",
          "default": true,
          "description": "Redact environment variable values from pod describe output before sending to AI.",
          "order": 21
        },
        "kubiq.guardrails.redactPatterns": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Additional regex patterns to redact from data sent to AI. Each match is replaced with [REDACTED].",
          "order": 22
        },
        "kubiq.guardrails.flagDestructiveCommands": {
          "type": "boolean",
          "default": true,
          "description": "Flag destructive kubectl commands (delete, drain, scale-to-zero) in AI responses with a warning banner.",
          "order": 30
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "node build.js",
    "compile": "node build.js",
    "watch": "node build.js --watch",
    "package": "node build.js && npx @vscode/vsce package --no-dependencies",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.ts\" \"*.json\" \"*.js\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"*.json\" \"*.js\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,js,md}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.4",
    "@commitlint/config-conventional": "^20.4.4",
    "@eslint/js": "^10.0.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.20.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "prettier": "^3.8.1",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.57.0",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "js-yaml": "^4.1.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/maddinenisri/kubiq.git"
  },
  "homepage": "https://github.com/maddinenisri/kubiq#readme",
  "bugs": {
    "url": "https://github.com/maddinenisri/kubiq/issues"
  },
  "license": "MIT"
}
