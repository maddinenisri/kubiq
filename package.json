{
  "name": "kubiq",
  "displayName": "Kubiq",
  "description": "Kubernetes intelligence for AWS EKS — pod diagnostics, crash analysis, multi-cluster management with AI",
  "version": "0.1.0",
  "publisher": "kubiq",
  "author": {
    "name": "Kubiq"
  },
  "icon": "media/kubiq-icon.png",
  "galleryBanner": {
    "color": "#0d0f14",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Debuggers"
  ],
  "keywords": [
    "kubernetes",
    "eks",
    "aws",
    "pod",
    "diagnostics",
    "kubectl",
    "crash",
    "logs",
    "kubiq"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "extensionDependencies": [
    "ms-kubernetes-tools.vscode-kubernetes-tools"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "kubiq.diagnosePod",
        "title": "Kubiq: Diagnose Pod",
        "icon": "$(pulse)"
      },
      {
        "command": "kubiq.refreshClusters",
        "title": "Kubiq: Refresh Clusters",
        "icon": "$(refresh)"
      }
    ],
    "menus": {
      "view/item/context": [
        {
          "command": "kubiq.diagnosePod",
          "when": "viewItem =~ /vsKubernetes\\.resource\\.pod/",
          "group": "kubiq@1"
        }
      ]
    },
    "configuration": {
      "title": "Kubiq",
      "properties": {
        "kubiq.clusterProfiles": {
          "type": "object",
          "default": {},
          "description": "Manual overrides: map kubeconfig context name to AWS profile.",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "profile": {
                "type": "string"
              },
              "region": {
                "type": "string"
              }
            }
          }
        },
        "kubiq.logTailLines": {
          "type": "number",
          "default": 500,
          "description": "Number of log lines to fetch per container"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "node build.js",
    "compile": "node build.js",
    "watch": "node build.js --watch",
    "package": "node build.js && npx @vscode/vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "@kubernetes/client-node": "^0.20.0",
    "js-yaml": "^4.1.0",
    "vscode-kubernetes-tools-api": "^1.3.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/maddinenisri/kubiq.git"
  },
  "homepage": "https://github.com/maddinenisri/kubiq#readme",
  "bugs": {
    "url": "https://github.com/maddinenisri/kubiq/issues"
  },
  "license": "MIT"
}
